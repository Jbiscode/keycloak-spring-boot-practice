# =============================================
# Keycloak + Spring Boot 학습 환경 환경변수
# =============================================
# 이 파일을 복사하여 .env 로 사용한다.
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=keycloak_secret

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Keycloak이 JWT iss 클레임에 사용하는 외부 접근 URL
# 브라우저/curl과 Spring Boot 검증 기준을 맞춘다
KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8080

# --- Spring Boot ---
# 로컬 실행 포트 (docker-compose에서 8081로 노출)
SERVER_PORT=8081
# JWT issuer 검증 기준 (Keycloak 외부 URL과 동일해야 함)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8080/realms/demo
# Docker 내부 통신용 JWK 주소 (컨테이너끼리 통신 시 서비스명 사용)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://keycloak:8080/realms/demo/protocol/openid-connect/certs
